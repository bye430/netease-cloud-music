{
  "name": "netease-cloud-music",
  "version": "1.0.0",
  "description": "网易云音乐 Web 播放器桌面壳",
  "homepage": "https://music.163.com/st/webplayer",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "shortcuts": "bash scripts/apply-shortcuts.sh",
    "install-ctl": "pkexec bash scripts/install-system-shortcuts.sh .",
    "install-fonts": "bash scripts/install-fonts.sh",
    "generate-icons": "bash scripts/generate-icons.sh",
    "pack": "npm run generate-icons && electron-builder --dir",
    "dist:deb": "npm run generate-icons && electron-builder --linux deb"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.netease.cloudmusic",
    "productName": "netease-cloud-music",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "lyrics.html",
      "lyrics-preload.js",
      "shortcuts.html",
      "shortcuts-preload.js",
      "assets/**/*",
      "scripts/**/*",
      "build/after-install.sh",
      "build/after-remove.sh"
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "icon": "build/icons",
      "category": "AudioVideo",
      "maintainer": "local <local@localhost>",
      "vendor": "netease-cloud-music",
      "synopsis": "网易云音乐",
      "description": "基于 Electron 的网易云音乐桌面客户端，支持系统托盘、歌词悬浮窗与媒体键控制。",
      "executableName": "netease-cloud-music",
      "executableArgs": [
        "--no-sandbox"
      ],
      "desktop": {
        "Name": "网易云音乐",
        "Name[zh_CN]": "网易云音乐",
        "GenericName": "音乐播放器",
        "GenericName[zh_CN]": "音乐播放器",
        "Comment": "网易云音乐桌面客户端",
        "Comment[zh_CN]": "网易云音乐桌面客户端",
        "Categories": "AudioVideo;Audio;Player;",
        "Icon": "netease-cloud-music",
        "StartupWMClass": "netease-cloud-music",
        "Keywords": "music;netease;cloud;player;audio;网易云;"
      }
    },
    "deb": {
      "afterInstall": "build/after-install.sh",
      "afterRemove": "build/after-remove.sh"
    }
  }
}
